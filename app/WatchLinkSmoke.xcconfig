#include "WatchOS.xcconfig"

PRODUCT_NAME = iSHWatchLinkSmoke
PRODUCT_BUNDLE_IDENTIFIER = app.ish.iSH.watch-link-smoke
GENERATE_INFOPLIST_FILE = YES
INFOPLIST_KEY_CFBundleDisplayName = iSH Watch Link Smoke
INFOPLIST_KEY_ITSAppUsesNonExemptEncryption = NO
INFOPLIST_KEY_WKWatchOnly = YES

HEADER_SEARCH_PATHS = $(inherited) $(SRCROOT)
LIBRARY_SEARCH_PATHS = $(inherited) $(ISH_WATCH_LIBRARY_DIR)
OTHER_LDFLAGS = $(inherited) -Wl,-fatal_warnings -lish -lish_emu -lfakefs -lm -ldl -lsqlite3
ONLY_ACTIVE_ARCH = NO
